      "source": [
        "array = [\"水\",\"金\",\"地\",\"火\",\"木\",\"土\",\"天\",\"海\",\"冥\"]\n",
        "\n",
        "# forループを使用してリストの要素を順に出力\n",
        "for element in array:\n",
        "    print(element)\n",
        "\n",
        "# whileループを使用してリストの要素を順に出力\n",
        "i = 0\n",
        "while i < len(array):\n",
        "    print(array[i])\n",
        "    i += 1"
      ],
