      "source": [
        "class Human:\n",
        "    def __init__(self, name: str, age: int):\n",
        "        self.name = name\n",
        "        self.age = age\n",
        "\n",
        "    def printinfo(self):\n",
        "        print(f\"名前: {self.name}, 年齢: {self.age}\")\n",
        "\n",
        "# Humanクラスのインスタンスを作成し、変数に代入\n",
        "human = Human(\"太郎\", 25)\n",
        "\n",
        "# printinfoメソッドを呼び出して情報を出力\n",
        "human.printinfo()"
      ],
