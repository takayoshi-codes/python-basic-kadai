      "source": [
        "def calculate_total_with_tax(price, tax_rate):\n",
        "    tax_amount = price * (tax_rate / 100)\n",
        "    total = price + tax_amount\n",
        "    return total\n",
        "\n",
        "result = calculate_total_with_tax(110, 10)\n",
        "print(result)"
